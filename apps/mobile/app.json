{
  "expo": {
    "name": "Sports Matchmaking",
    "slug": "sports-matchmaking",
    "scheme": "sportsmatchmaking",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sports Matchmaking to use your location for nearby match discovery."
        }
      ]
    ]
  }
}
