generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SportFormat {
  SINGLES
  DOUBLES
}

enum MatchStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum MatchParticipantStatus {
  JOINED
  LEFT
  NO_SHOW
}

enum Team {
  A
  B
  UNKNOWN
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ModerationActionType {
  REPORT_REVIEWED
  REPORT_DISMISSED
  DISPUTE_RESOLVED
  DISPUTE_REJECTED
  NO_SHOW_CONFIRMED
  NO_SHOW_REVERSED
}

enum NotificationType {
  MATCH_JOINED
  MATCH_LEFT
  MATCH_CANCELLED
  CHAT_MESSAGE
  RESULT_SUBMITTED
  RESULT_VERIFIED
  RATING_UPDATED
  DISPUTE_CREATED
  REPORT_CREATED
  NO_SHOW_MARKED
  AUTO_MATCH_FOUND
  AUTO_MATCH_CONFIRMED
  AUTO_MATCH_DECLINED
  AUTO_MATCH_EXPIRED
  AUTO_MATCH_LOCATION_PROPOSED
  AUTO_MATCH_LOCATION_ACCEPTED
  AUTO_MATCH_LOCATION_DECLINED
  AUTO_MATCH_CANCELLED
  SYSTEM
}

enum PushDevicePlatform {
  IOS
  ANDROID
  WEB
  UNKNOWN
}

enum MatchmakingTicketStatus {
  SEARCHING
  MATCHED
  CANCELLED
  EXPIRED
}

enum MatchmakingProposalStatus {
  PENDING
  CONFIRMED
  DECLINED
  EXPIRED
  CANCELLED
}

enum MatchmakingProposalParticipantStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MatchmakingLocationProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum CheckInMethod {
  MANUAL
  GPS
  QR
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String?
  role             UserRole          @default(USER)
  displayName      String
  bio              String?
  homeLocationText String?
  avatarUrl        String?
  skillDescription String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdMatches   Match[]           @relation("MatchCreatedBy")
  participations   MatchParticipant[]
  submittedResults MatchResult[]     @relation("ResultSubmittedBy")
  correctedResults MatchResult[]     @relation("ResultCorrectedBy")
  ratings          UserSportRating[]
  ratingHistory    RatingHistory[]
  reliabilityStats UserReliabilityStats?
  createdDisputes  MatchResultDispute[] @relation("DisputeCreatedBy")
  reportsFiled     UserReport[] @relation("ReportBy")
  reportsReceived  UserReport[] @relation("ReportedUser")
  reviewedReports  UserReport[] @relation("ReportReviewedBy")
  reviewedDisputes MatchResultDispute[] @relation("DisputeReviewedBy")
  sentChatMessages ChatMessage[] @relation("ChatMessageSender")
  notifications    Notification[]
  pushDevices      PushDevice[]
  notificationPreference NotificationPreference?
  matchNotificationPreferences MatchNotificationPreference[]
  chatReadStates ChatReadState[]
  moderationActions ModerationAction[] @relation("ModerationBy")
  sportPreferences UserSportPreference[]
  preferredVenues UserPreferredVenue[]
  availabilitySlots UserAvailabilitySlot[]
  matchmakingTickets MatchmakingTicket[]
  matchmakingProposalParticipants MatchmakingProposalParticipant[]
  matchmakingProposalMessages MatchmakingProposalMessage[]
  matchmakingLocationProposals MatchmakingLocationProposal[]
  matchmakingLocationProposalResponses MatchmakingLocationProposalResponse[]
}

model Sport {
  id            String            @id @default(uuid())
  name          String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  matches       Match[]
  userRatings   UserSportRating[]
  ratingHistory RatingHistory[]
  userSportPreferences UserSportPreference[]
  matchmakingTickets MatchmakingTicket[]
  matchmakingProposals MatchmakingProposal[]
}

model UserSportRating {
  id          String      @id @default(uuid())
  userId      String
  sportId     String
  format      SportFormat
  rating      Int         @default(1200)
  gamesPlayed Int         @default(0)
  uncertainty Float       @default(350)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport       Sport       @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId, format])
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  googleMapsUrl String?
  googlePlaceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches   Match[]
  preferredByUsers UserPreferredVenue[]
  matchmakingTickets MatchmakingTicket[] @relation("MatchmakingTicketPreferredVenue")
  matchmakingProposals MatchmakingProposal[]
}

model UserSportPreference {
  id                 String   @id @default(uuid())
  userId             String
  sportId            String
  prefersSingles     Boolean  @default(true)
  prefersDoubles     Boolean  @default(true)
  minPreferredRating Int?
  maxPreferredRating Int?
  priority           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport              Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId])
  @@index([userId, priority])
}

model UserPreferredVenue {
  id        String   @id @default(uuid())
  userId    String
  venueId   String
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId, priority])
}

model UserAvailabilitySlot {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String   @default("Asia/Singapore")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek, startTime])
}

model Match {
  id              String    @id @default(uuid())
  sportId         String
  venueId         String?
  createdByUserId String
  title           String
  description     String?
  format          SportFormat
  status          MatchStatus
  startsAt        DateTime
  maxPlayers      Int
  minRating       Int?
  maxRating       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sport           Sport      @relation(fields: [sportId], references: [id], onDelete: Restrict)
  venue           Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  createdByUser   User       @relation("MatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  participants    MatchParticipant[]
  result          MatchResult?
  ratingHistory   RatingHistory[]
  disputes        MatchResultDispute[]
  reports         UserReport[]
  chatMessages    ChatMessage[]
  matchNotificationPreferences MatchNotificationPreference[]
  chatReadStates ChatReadState[]
  moderationActions ModerationAction[]
  matchmakingProposals MatchmakingProposal[] @relation("MatchmakingProposalConfirmedMatch")

  @@index([sportId, status, startsAt])
  @@index([venueId, startsAt])
  @@index([format, status])
}

model ChatMessage {
  id           String   @id @default(uuid())
  matchId      String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender       User     @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([senderUserId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PushDevice {
  id            String             @id @default(uuid())
  userId        String
  expoPushToken String             @unique
  platform      PushDevicePlatform?
  deviceName    String?
  isActive      Boolean            @default(true)
  lastSeenAt    DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  matchUpdates  Boolean  @default(true)
  chatMessages  Boolean  @default(true)
  results       Boolean  @default(true)
  trustSafety   Boolean  @default(true)
  ratingUpdates Boolean  @default(true)
  quietHoursEnabled Boolean @default(false)
  quietHoursStart String?
  quietHoursEnd String?
  timezone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchNotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  muted     Boolean  @default(false)
  muteUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId, userId])
}

model ChatReadState {
  id         String   @id @default(uuid())
  userId     String
  matchId    String
  lastReadAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId, userId])
}

model MatchParticipant {
  id        String                 @id @default(uuid())
  matchId   String
  userId    String
  status    MatchParticipantStatus
  team      Team
  checkedInAt DateTime?
  checkInMethod CheckInMethod?
  checkedInLatitude Float?
  checkedInLongitude Float?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  match     Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationActions ModerationAction[]

  @@unique([matchId, userId])
}

model MatchResult {
  id                String   @id @default(uuid())
  matchId           String   @unique
  submittedByUserId String
  teamAScore        Int
  teamBScore        Int
  verified          Boolean  @default(false)
  correctedTeamAScore Int?
  correctedTeamBScore Int?
  correctedByUserId String?
  correctedAt      DateTime?
  correctionReason String?
  isCorrected      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedByUser   User     @relation("ResultSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: Restrict)
  correctedByUser   User?    @relation("ResultCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)
  disputes          MatchResultDispute[]
}

model RatingHistory {
  id        String   @id @default(uuid())
  userId    String
  sportId   String
  matchId   String
  oldRating Int
  newRating Int
  delta     Int
  correctionOfRatingHistoryId String?
  isReverted Boolean @default(false)
  revertedAt DateTime?
  revertReason String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport     Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, sportId, createdAt])
  @@index([matchId, createdAt])
}

model UserReliabilityStats {
  id                    String   @id @default(uuid())
  userId                String   @unique
  completedMatches      Int      @default(0)
  cancelledMatches      Int      @default(0)
  lateCancellationCount Int      @default(0)
  noShowCount           Int      @default(0)
  disputedResults       Int      @default(0)
  reportCount           Int      @default(0)
  reliabilityScore      Int      @default(100)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchResultDispute {
  id              String       @id @default(uuid())
  matchResultId   String
  matchId         String
  createdByUserId String
  reason          String
  status          DisputeStatus @default(OPEN)
  reviewedByUserId String?
  reviewedAt      DateTime?
  moderatorNote   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  matchResult     MatchResult  @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  match           Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation("DisputeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  reviewedByUser  User?        @relation("DisputeReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@unique([matchResultId, createdByUserId])
  @@index([matchId, status])
}

model UserReport {
  id             String      @id @default(uuid())
  reportedUserId String
  reporterUserId String
  matchId        String?
  reason         String
  status         ReportStatus @default(OPEN)
  reviewedByUserId String?
  reviewedAt     DateTime?
  moderatorNote  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  reportedUser   User        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporterUser   User        @relation("ReportBy", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reviewedByUser User?       @relation("ReportReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  match          Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([reportedUserId, status])
  @@index([reporterUserId, createdAt])
}

model ModerationAction {
  id              String               @id @default(uuid())
  moderatorUserId String
  targetUserId    String?
  reportId        String?
  disputeId       String?
  matchId         String?
  participantId   String?
  actionType      ModerationActionType
  note            String?
  metadata        Json?
  createdAt       DateTime             @default(now())

  moderatorUser   User                 @relation("ModerationBy", fields: [moderatorUserId], references: [id], onDelete: Cascade)
  report          UserReport?          @relation(fields: [reportId], references: [id], onDelete: SetNull)
  dispute         MatchResultDispute?  @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  match           Match?               @relation(fields: [matchId], references: [id], onDelete: SetNull)
  participant     MatchParticipant?    @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([moderatorUserId, createdAt])
  @@index([targetUserId, createdAt])
}

model MatchmakingTicket {
  id               String                  @id @default(uuid())
  userId           String
  sportId          String
  format           SportFormat
  latitude         Float?
  longitude        Float?
  radiusKm         Float                   @default(5)
  earliestStart    DateTime
  latestEnd        DateTime
  preferredVenueId String?
  minElo           Int?
  maxElo           Int?
  status           MatchmakingTicketStatus @default(SEARCHING)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  expiresAt        DateTime

  user                 User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport                Sport                           @relation(fields: [sportId], references: [id], onDelete: Cascade)
  preferredVenue       Venue?                          @relation("MatchmakingTicketPreferredVenue", fields: [preferredVenueId], references: [id], onDelete: SetNull)
  proposalParticipants MatchmakingProposalParticipant[]

  @@index([sportId, format, status, createdAt])
  @@index([userId, sportId, format, status])
}

model MatchmakingProposal {
  id                String                     @id @default(uuid())
  sportId           String
  format            SportFormat
  venueId           String?
  proposedStartTime DateTime
  status            MatchmakingProposalStatus  @default(PENDING)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  confirmedMatchId  String?

  sport          Sport                           @relation(fields: [sportId], references: [id], onDelete: Cascade)
  venue          Venue?                          @relation(fields: [venueId], references: [id], onDelete: SetNull)
  confirmedMatch Match?                          @relation("MatchmakingProposalConfirmedMatch", fields: [confirmedMatchId], references: [id], onDelete: SetNull)
  participants   MatchmakingProposalParticipant[]
  messages       MatchmakingProposalMessage[]
  locationProposals MatchmakingLocationProposal[]

  @@index([status, createdAt])
  @@index([sportId, format, status])
}

model MatchmakingProposalParticipant {
  id          String                               @id @default(uuid())
  proposalId  String
  userId      String
  ticketId    String
  team        Team                                 @default(UNKNOWN)
  status      MatchmakingProposalParticipantStatus @default(PENDING)
  createdAt   DateTime                             @default(now())
  updatedAt   DateTime                             @updatedAt
  respondedAt DateTime?

  proposal MatchmakingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket   MatchmakingTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([userId, status, createdAt])
}

model MatchmakingProposalMessage {
  id           String   @id @default(uuid())
  proposalId   String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  proposal     MatchmakingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([senderUserId, createdAt])
}

model MatchmakingLocationProposal {
  id             String                           @id @default(uuid())
  proposalId     String
  proposedByUserId String
  locationName   String
  address        String?
  latitude       Float
  longitude      Float
  googleMapsUrl  String?
  googlePlaceId  String?
  status         MatchmakingLocationProposalStatus @default(PENDING)
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  acceptedAt     DateTime?
  cancelledAt    DateTime?

  proposal       MatchmakingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposedByUser User                @relation(fields: [proposedByUserId], references: [id], onDelete: Cascade)
  responses      MatchmakingLocationProposalResponse[]

  @@index([proposalId, status, createdAt])
}

model MatchmakingLocationProposalResponse {
  id                 String                               @id @default(uuid())
  locationProposalId String
  userId             String
  status             MatchmakingProposalParticipantStatus @default(PENDING)
  createdAt          DateTime                             @default(now())
  updatedAt          DateTime                             @updatedAt
  respondedAt        DateTime?

  locationProposal   MatchmakingLocationProposal @relation(fields: [locationProposalId], references: [id], onDelete: Cascade)
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locationProposalId, userId])
  @@index([userId, status, createdAt])
}
