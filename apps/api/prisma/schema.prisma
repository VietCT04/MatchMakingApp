generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SportFormat {
  SINGLES
  DOUBLES
}

enum MatchStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum MatchParticipantStatus {
  JOINED
  LEFT
  NO_SHOW
}

enum Team {
  A
  B
  UNKNOWN
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ModerationActionType {
  REPORT_REVIEWED
  REPORT_DISMISSED
  DISPUTE_RESOLVED
  DISPUTE_REJECTED
  NO_SHOW_CONFIRMED
  NO_SHOW_REVERSED
}

enum NotificationType {
  MATCH_JOINED
  MATCH_LEFT
  MATCH_CANCELLED
  CHAT_MESSAGE
  RESULT_SUBMITTED
  RESULT_VERIFIED
  RATING_UPDATED
  DISPUTE_CREATED
  REPORT_CREATED
  NO_SHOW_MARKED
  SYSTEM
}

enum PushDevicePlatform {
  IOS
  ANDROID
  WEB
  UNKNOWN
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String?
  role             UserRole          @default(USER)
  displayName      String
  bio              String?
  homeLocationText String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdMatches   Match[]           @relation("MatchCreatedBy")
  participations   MatchParticipant[]
  submittedResults MatchResult[]     @relation("ResultSubmittedBy")
  correctedResults MatchResult[]     @relation("ResultCorrectedBy")
  ratings          UserSportRating[]
  ratingHistory    RatingHistory[]
  reliabilityStats UserReliabilityStats?
  createdDisputes  MatchResultDispute[] @relation("DisputeCreatedBy")
  reportsFiled     UserReport[] @relation("ReportBy")
  reportsReceived  UserReport[] @relation("ReportedUser")
  reviewedReports  UserReport[] @relation("ReportReviewedBy")
  reviewedDisputes MatchResultDispute[] @relation("DisputeReviewedBy")
  sentChatMessages ChatMessage[] @relation("ChatMessageSender")
  notifications    Notification[]
  pushDevices      PushDevice[]
  notificationPreference NotificationPreference?
  matchNotificationPreferences MatchNotificationPreference[]
  chatReadStates ChatReadState[]
  moderationActions ModerationAction[] @relation("ModerationBy")
}

model Sport {
  id            String            @id @default(uuid())
  name          String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  matches       Match[]
  userRatings   UserSportRating[]
  ratingHistory RatingHistory[]
}

model UserSportRating {
  id          String      @id @default(uuid())
  userId      String
  sportId     String
  format      SportFormat
  rating      Int         @default(1200)
  gamesPlayed Int         @default(0)
  uncertainty Float       @default(350)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport       Sport       @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId, format])
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches   Match[]
}

model Match {
  id              String    @id @default(uuid())
  sportId         String
  venueId         String?
  createdByUserId String
  title           String
  description     String?
  format          SportFormat
  status          MatchStatus
  startsAt        DateTime
  maxPlayers      Int
  minRating       Int?
  maxRating       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sport           Sport      @relation(fields: [sportId], references: [id], onDelete: Restrict)
  venue           Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  createdByUser   User       @relation("MatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  participants    MatchParticipant[]
  result          MatchResult?
  ratingHistory   RatingHistory[]
  disputes        MatchResultDispute[]
  reports         UserReport[]
  chatMessages    ChatMessage[]
  matchNotificationPreferences MatchNotificationPreference[]
  chatReadStates ChatReadState[]
  moderationActions ModerationAction[]

  @@index([sportId, status, startsAt])
  @@index([venueId, startsAt])
  @@index([format, status])
}

model ChatMessage {
  id           String   @id @default(uuid())
  matchId      String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender       User     @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([senderUserId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PushDevice {
  id            String             @id @default(uuid())
  userId        String
  expoPushToken String             @unique
  platform      PushDevicePlatform?
  deviceName    String?
  isActive      Boolean            @default(true)
  lastSeenAt    DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  matchUpdates  Boolean  @default(true)
  chatMessages  Boolean  @default(true)
  results       Boolean  @default(true)
  trustSafety   Boolean  @default(true)
  ratingUpdates Boolean  @default(true)
  quietHoursEnabled Boolean @default(false)
  quietHoursStart String?
  quietHoursEnd String?
  timezone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchNotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  muted     Boolean  @default(false)
  muteUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId, userId])
}

model ChatReadState {
  id         String   @id @default(uuid())
  userId     String
  matchId    String
  lastReadAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId, userId])
}

model MatchParticipant {
  id        String                 @id @default(uuid())
  matchId   String
  userId    String
  status    MatchParticipantStatus
  team      Team
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  match     Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationActions ModerationAction[]

  @@unique([matchId, userId])
}

model MatchResult {
  id                String   @id @default(uuid())
  matchId           String   @unique
  submittedByUserId String
  teamAScore        Int
  teamBScore        Int
  verified          Boolean  @default(false)
  correctedTeamAScore Int?
  correctedTeamBScore Int?
  correctedByUserId String?
  correctedAt      DateTime?
  correctionReason String?
  isCorrected      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedByUser   User     @relation("ResultSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: Restrict)
  correctedByUser   User?    @relation("ResultCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)
  disputes          MatchResultDispute[]
}

model RatingHistory {
  id        String   @id @default(uuid())
  userId    String
  sportId   String
  matchId   String
  oldRating Int
  newRating Int
  delta     Int
  correctionOfRatingHistoryId String?
  isReverted Boolean @default(false)
  revertedAt DateTime?
  revertReason String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport     Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, sportId, createdAt])
  @@index([matchId, createdAt])
}

model UserReliabilityStats {
  id                    String   @id @default(uuid())
  userId                String   @unique
  completedMatches      Int      @default(0)
  cancelledMatches      Int      @default(0)
  lateCancellationCount Int      @default(0)
  noShowCount           Int      @default(0)
  disputedResults       Int      @default(0)
  reportCount           Int      @default(0)
  reliabilityScore      Int      @default(100)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchResultDispute {
  id              String       @id @default(uuid())
  matchResultId   String
  matchId         String
  createdByUserId String
  reason          String
  status          DisputeStatus @default(OPEN)
  reviewedByUserId String?
  reviewedAt      DateTime?
  moderatorNote   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  matchResult     MatchResult  @relation(fields: [matchResultId], references: [id], onDelete: Cascade)
  match           Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation("DisputeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  reviewedByUser  User?        @relation("DisputeReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@unique([matchResultId, createdByUserId])
  @@index([matchId, status])
}

model UserReport {
  id             String      @id @default(uuid())
  reportedUserId String
  reporterUserId String
  matchId        String?
  reason         String
  status         ReportStatus @default(OPEN)
  reviewedByUserId String?
  reviewedAt     DateTime?
  moderatorNote  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  reportedUser   User        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporterUser   User        @relation("ReportBy", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reviewedByUser User?       @relation("ReportReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  match          Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([reportedUserId, status])
  @@index([reporterUserId, createdAt])
}

model ModerationAction {
  id              String               @id @default(uuid())
  moderatorUserId String
  targetUserId    String?
  reportId        String?
  disputeId       String?
  matchId         String?
  participantId   String?
  actionType      ModerationActionType
  note            String?
  metadata        Json?
  createdAt       DateTime             @default(now())

  moderatorUser   User                 @relation("ModerationBy", fields: [moderatorUserId], references: [id], onDelete: Cascade)
  report          UserReport?          @relation(fields: [reportId], references: [id], onDelete: SetNull)
  dispute         MatchResultDispute?  @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  match           Match?               @relation(fields: [matchId], references: [id], onDelete: SetNull)
  participant     MatchParticipant?    @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([moderatorUserId, createdAt])
  @@index([targetUserId, createdAt])
}
