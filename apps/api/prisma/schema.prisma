generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SportFormat {
  SINGLES
  DOUBLES
}

enum MatchStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum MatchParticipantStatus {
  JOINED
  LEFT
  NO_SHOW
}

enum Team {
  A
  B
  UNKNOWN
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String?
  displayName      String
  bio              String?
  homeLocationText String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdMatches   Match[]           @relation("MatchCreatedBy")
  participations   MatchParticipant[]
  submittedResults MatchResult[]     @relation("ResultSubmittedBy")
  ratings          UserSportRating[]
  ratingHistory    RatingHistory[]
}

model Sport {
  id            String            @id @default(uuid())
  name          String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  matches       Match[]
  userRatings   UserSportRating[]
  ratingHistory RatingHistory[]
}

model UserSportRating {
  id          String      @id @default(uuid())
  userId      String
  sportId     String
  format      SportFormat
  rating      Int         @default(1200)
  gamesPlayed Int         @default(0)
  uncertainty Float       @default(350)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport       Sport       @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId, format])
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches   Match[]
}

model Match {
  id              String    @id @default(uuid())
  sportId         String
  venueId         String?
  createdByUserId String
  title           String
  description     String?
  format          SportFormat
  status          MatchStatus
  startsAt        DateTime
  maxPlayers      Int
  minRating       Int?
  maxRating       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sport           Sport      @relation(fields: [sportId], references: [id], onDelete: Restrict)
  venue           Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  createdByUser   User       @relation("MatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  participants    MatchParticipant[]
  result          MatchResult?
  ratingHistory   RatingHistory[]

  @@index([sportId, status, startsAt])
  @@index([venueId, startsAt])
  @@index([format, status])
}

model MatchParticipant {
  id        String                 @id @default(uuid())
  matchId   String
  userId    String
  status    MatchParticipantStatus
  team      Team
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  match     Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

model MatchResult {
  id                String   @id @default(uuid())
  matchId           String   @unique
  submittedByUserId String
  teamAScore        Int
  teamBScore        Int
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedByUser   User     @relation("ResultSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: Restrict)
}

model RatingHistory {
  id        String   @id @default(uuid())
  userId    String
  sportId   String
  matchId   String
  oldRating Int
  newRating Int
  delta     Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport     Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, sportId, createdAt])
}
